{
  "_v": 2,
  "platforms": {
    "gemini": {
      "selectors": {
        "input": [
          "div[role=\"textbox\"][aria-label=\"Enter a prompt for Gemini\"]",
          "div[role=\"textbox\"][aria-label=\"Ask Gemini\"]",
          "[contenteditable=\"true\"][role=\"textbox\"]"
        ],
        "sendButton": [
          "button[aria-label=\"Send message\"]",
          "button[aria-label=\"Submit prompt\"]"
        ],
        "chatHistory": [
          "#chat-history",
          "[data-test-id=\"conversation\"]",
          "[role=\"feed\"]",
          "[role=\"log\"]"
        ]
      },
      "messageDetection": {
        "msgIdSelectors": [
          "[data-test-id=\"message\"]",
          "[data-test-id=\"conversation-turn\"]",
          "[data-message-id]",
          "[data-e2e-id]"
        ],
        "userIndicators": [
          ".user-profile-picture",
          "[data-test-id=\"user-input\"]",
          "[data-role=\"user\"]",
          "[data-message-role=\"user\"]"
        ],
        "textPatterns": [
          "Enter a prompt",
          "Ask Gemini"
        ]
      }
    },
    "claude": {
      "selectors": {
        "input": [
          "div[contenteditable=\"true\"][role=\"textbox\"][data-testid=\"chat-input\"]",
          "div.tiptap.ProseMirror"
        ],
        "sendButton": [],
        "chatHistory": [
          "div[data-autoscroll-container=\"true\"]"
        ]
      },
      "messageDetection": {
        "msgIdSelectors": [
          "[data-testid=\"user-message\"]"
        ],
        "userIndicators": [
          "[data-user-message-bubble=\"true\"]"
        ],
        "textPatterns": []
      }
    }
  },
  "anchor_version": "3.6.0",
  "profile": "finance_wealth_advisory",
  "extension_config": {
    "target_engine": "hardware_bound",
    "vram_guard": true,
    "compact_payload": true
  },
  "prompt_assembly": {
    "role_definition": "Wealth Advisory Analyst",
    "reasoning_protocol": "Analyze, Validate, Summarize",
    "domain_focus": [
      "Cryptocurrency (BTC, ETH, SUI)",
      "Australian Property Market (Victoria)",
      "Precious Metals"
    ],
    "output_requirements": {
      "format": "Markdown tables for comparisons; bulleted analysis.",
      "clarity": "Professional, plain language; avoid jargon and hype.",
      "compliance": "Explicitly state: 'This is educational information, not licensed financial advice.' Direct users to professionals for tax/legal issues."
    },
    "behavioral_protocols": {
      "tone": "Professional, objective, and analytical.",
      "interaction_style": "If the query is ambiguous, ask 1-2 clarifying questions before providing a recommendation.",
      "uncertainty": "If data is insufficient, state: 'I do not have sufficient information to answer this reliably,' and suggest expert consultation."
    }
  }
}
