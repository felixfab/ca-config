{
  "version": 2,
  "platforms": {
    "gemini": {
      "selectors": {
        "input": [
          "div[role=\"textbox\"][aria-label=\"Enter a prompt for Gemini\"]",
          "div[role=\"textbox\"][aria-label=\"Ask Gemini\"]",
          "div[role=\"textbox\"][aria-label=\"Ask anything\"]",
          "div[role=\"textbox\"][contenteditable=\"true\"]"
        ],
        "sendButton": [],
        "chatHistory": [
          ".conversation-container",
          "[data-test-id=\"conversation-container\"]",
          "main",
          "#chat-history",
          "[data-test-id=\"conversation\"]",
          "[role=\"feed\"]",
          "[role=\"log\"]",
          "infinite-scroller[data-test-id=\"chat-history-container\"]",
          ".chat-history"
        ]
      },
      "messageDetection": {
        "msgIdSelectors": [
          "user-query",
          "model-response"
        ],
        "userIndicators": [
          "user-query",
          ".user-query",
          "[data-test-id=\"user-query\"]",
          ".user-profile-picture",
          "[data-test-id=\"user-input\"]",
          "[data-role=\"user\"]",
          "[data-message-role=\"user\"]"
        ],
        "textPatterns": [
          "Enter a prompt",
          "Ask Gemini",
          "Ask anything"
        ]
      }
    },
    "claude": {
      "selectors": {
        "input": [
          "div[contenteditable=\"true\"][role=\"textbox\"][data-testid=\"chat-input\"]",
          "div.tiptap.ProseMirror"
        ],
        "sendButton": [],
        "chatHistory": [
          "div[data-autoscroll-container=\"true\"]"
        ]
      },
      "messageDetection": {
        "msgIdSelectors": [
          "[data-testid=\"user-message\"]"
        ],
        "userIndicators": [
          "[data-user-message-bubble=\"true\"]"
        ],
        "textPatterns": []
      }
    }
  },
  "prompt_assembly": {
    "role_definition": "Helpful Assistant",
    "reasoning_protocol": "Think step-by-step before responding",
    "domain_focus": [],
    "tone_profile": {
      "tone": "Clear, concise, and helpful",
      "avoid": ""
    },
    "socratic_trigger": "",
    "output_requirements": {
      "format": "",
      "clarity": "",
      "compliance": ""
    },
    "uncertainty_protocol": ""
  },
  "extension_config": {
    "cmaThreshold": 5
  }
}
